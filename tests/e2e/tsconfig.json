{
  "extends": "../../tsconfig.server.json",
  "compilerOptions": {
    "rootDir": "../..",
    "noEmit": true,
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.e2e.tsbuildinfo",
    // DOM lib is needed for the page.evaluate snippets that touch
    // `document`, `window`, `PerformanceObserver`, `HTMLElement`. The
    // snippets run in the browser; this file just needs the types.
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
