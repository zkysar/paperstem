GMAIL_USER=
GMAIL_APP_PASSWORD=
APP_URL=http://localhost:5173
DATABASE_PATH=./dev.sqlite
PORT=8787
SESSION_COOKIE_SECRET=

# In dev, replace Google Drive with a local directory. When set, all drive
# operations (createFolder, uploadFile, getDriveFile, ...) read/write under
# this path. Leave empty in prod. After setting, run:
#   PAPERSTEM_LOCAL_DRIVE_ROOT=./drive-dev tsx bin/init-local-drive.ts
# to point existing bands at a real local folder.
PAPERSTEM_LOCAL_DRIVE_ROOT=

# Production-only: Google Drive OAuth (unused when PAPERSTEM_LOCAL_DRIVE_ROOT is set).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
